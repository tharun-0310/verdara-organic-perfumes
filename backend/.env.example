PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<AppName>
# Get this from: Atlas Dashboard → Cluster → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxxx.mongodb.net/verdara-organic-perfumes?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=replace_with_a_very_long_secure_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
NODE_ENV=development
